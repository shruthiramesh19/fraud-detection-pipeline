# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
RAW_TOPIC=transactions.raw
ALERT_TOPIC=transactions.alerts
PRODUCER_TPS=2

# PostgreSQL
POSTGRES_USER=frauduser
POSTGRES_PASSWORD=your-password-here
POSTGRES_DB=frauddb
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://frauduser:your-password-here@db:5432/frauddb

# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Detection
ESCALATION_THRESHOLD=0.75
GPT_ESCALATION_ENABLED=true

# Grafana
GRAFANA_PASSWORD=admin123
