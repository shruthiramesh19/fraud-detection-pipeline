      "title": "Avg Confidence Score",
      "type": "stat",
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT COALESCE(ROUND(AVG(confidence_score)::numeric, 2), 0) FROM alerts",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "single" }
      },
      "title": "Alerts Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT date_trunc('minute', created_at) AS time, COUNT(*) AS alerts FROM alerts WHERE created_at > NOW() - INTERVAL '1 hour' GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "title": "Alerts by Risk Level",
      "type": "piechart",
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "value", "percent"],
        "legendDisplayMode": "table",
        "legendPlacement": "right"
      },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT COALESCE(gpt_risk_level, 'unescalated') AS \"Risk Level\", COUNT(*) AS \"Count\" FROM alerts GROUP BY 1 ORDER BY 2 DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {
            "fields": ["Risk Level"]
          }
        }
      ]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 8,
      "title": "Top Flagged Accounts",
      "type": "barchart",
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT account_id, COUNT(*) AS alert_count FROM alerts GROUP BY account_id ORDER BY alert_count DESC LIMIT 10",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "id": 9,
      "title": "Detection Tier Breakdown",
      "type": "piechart",
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "value", "percent"],
        "legendDisplayMode": "table",
        "legendPlacement": "right"
      },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT detection_tier AS \"Tier\", COUNT(*) AS \"Count\" FROM alerts GROUP BY 1 ORDER BY 2 DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "partitionByValues",
          "options": {
            "fields": ["Tier"]
          }
        }
      ]
    },
    {
      "datasource": "PostgreSQL",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "amount" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }]
          },
          {
            "matcher": { "id": "byName", "options": "confidence_score" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "id": 10,
      "title": "Recent Alerts Feed",
      "type": "table",
      "options": { "sortBy": [{ "displayName": "created_at", "desc": true }] },
      "targets": [
        {
          "datasource": "PostgreSQL",
          "rawSql": "SELECT a.created_at, a.account_id, t.amount, t.merchant, t.location, a.confidence_score, a.detection_tier, a.gpt_risk_level, a.gpt_reasoning FROM alerts a JOIN transactions t ON t.transaction_id = a.transaction_id ORDER BY a.created_at DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
